{
  "manifest_version": 3,
  "name": "WhisperStash Local Decrypt",
  "version": "1.0.0",
  "description": "Decrypt ENC[...] text blocks using local WhisperStash daemon.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["http://127.0.0.1:8765/*"],
  "action": {
    "default_title": "WhisperStash",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
